        <Node ToolID="8">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="849" y="189.9999" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField expression="// calculate the unicode value of the char&#xA;CharToInt([Text])" field="int_val" size="4" type="Int32" />
                <FormulaField expression="IntToBin([int_val])" field="bin_val" size="1073741823" type="V_WString" />
                <FormulaField expression="// generate the utf8 binary value of the character&#xA;IF [int_val] &lt;= HexToNumber('007F') THEN PadLeft([bin_val],8,'0') &#xA;ELSEIF [int_val] &lt;= HexToNumber('07FF') THEN &#xA;'110'+Substring(PadLeft([bin_val],11,'0'),0,5)+'10'+Substring(PadLeft([bin_val],11,'0'),5,6)&#xA;ELSEIF [int_val] &lt;= HexToNumber('FFFF') THEN &#xA;'1110'+Substring(PadLeft([bin_val],16,'0'),0,4)+'10'+Substring(PadLeft([bin_val],16,'0'),4,6)+'10'+Substring(PadLeft([bin_val],16,'0'),10,6)&#xA;ELSE &#xA;'11110'+Substring(PadLeft([bin_val],21,'0'),0,3)+'10'+Substring(PadLeft([bin_val],21,'0'),3,6)+'10'+Substring(PadLeft([bin_val],21,'0'),9,6)+'10'+Substring(PadLeft([bin_val],21,'0'),15,6)&#xA;ENDIF" field="utf8_bin_val" size="64" type="V_String" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText>int_val = // calculate the unicode value of the char
CharToInt([Text])
bin_val =...</DefaultAnnotationText>
              <Left value="False" />
            </Annotation>
            <MetaInfo connection="Output">
              <RecordInfo>
                <Field name="TextID" source="RecordID: Starting Value=1" type="Int32" />
                <Field name="Text" size="1073741823" source="TextInput:" type="V_WString" />
                <Field name="pad" size="64" source="Formula: IF Mod(Length([Text]), 3) == 1 THEN &#xA;'==' &#xA;ELSEIF &#xA;Mod(Length([Text]), 3) == 2 THEN &#xA;'=' &#xA;ELSE &#xA;''&#xA;ENDIF" type="V_String" />
                <Field name="char_seq" source="RecordID: Starting Value=1" type="Int32" />
                <Field name="int_val" source="Formula: // calculate the unicode value of the char&#xA;CharToInt([Text])" type="Int32" />
                <Field name="bin_val" size="1073741823" source="Formula: IntToBin([int_val])" type="V_WString" />
                <Field name="utf8_bin_val" size="64" source="Formula: // generate the utf8 binary value of the character&#xA;IF [int_val] &lt;= HexToNumber('007F') THEN PadLeft([bin_val],8,'0') &#xA;ELSEIF [int_val] &lt;= HexToNumber('07FF') THEN &#xA;'110'+Substring(PadLeft([bin_val],11,'0'),0,5)+'10'+Substring(PadLeft([bin_val],11,'0'),5,6)&#xA;ELSEIF [int_val] &lt;= HexToNumber('FFFF') THEN &#xA;'1110'+Substring(PadLeft([bin_val],16,'0'),0,4)+'10'+Substring(PadLeft([bin_val],16,'0'),4,6)+'10'+Substring(PadLeft([bin_val],16,'0'),10,6)&#xA;ELSE &#xA;'11110'+Substring(PadLeft([bin_val],21,'0'),0,3)+'10'+Substring(PadLeft([bin_val],21,'0'),3,6)+'10'+Substring(PadLeft([bin_val],21,'0'),9,6)+'10'+Substring(PadLeft([bin_val],21,'0'),15,6)&#xA;ENDIF" type="V_String" />
              </RecordInfo>
            </MetaInfo>
