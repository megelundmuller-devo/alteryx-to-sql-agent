            <Action>
              <Type>Error</Type>
              <Description>'Client ID, Client Secret, and Refresh Token are required to retrieve data.'</Description>
              <ToolId value="351" />
              <Expression>![#1] &amp;&amp; IsEmpty([#2]) &amp;&amp; IsEmpty([#3]) &amp;&amp; IsEmpty([#4])</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'The Profile (View) ID and Metric fields are required to retrieve data.'</Description>
              <ToolId value="371" />
              <Expression>IsEmpty([#1]) || IsEmpty([#2])</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'A Start and End date are required to retrieve data.'</Description>
              <ToolId value="373" />
              <Expression>[#1] &amp;&amp; IsEmpty([#2]) || [#1] &amp;&amp; IsEmpty([#3])</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>"The 'Dimensions' option is enabled but no measures have been added."</Description>
              <ToolId value="384" />
              <Expression>[#1] &amp;&amp; [#2] &amp;&amp; IsEmpty([#3])</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'Too many Dimensions have been added.'</Description>
              <ToolId value="385" />
              <Expression>[#1] &amp;&amp; [#2] &amp;&amp; REGEX_CountMatches([#3], '\n') + 1 &gt; 7</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>"The 'Segments' option is enabled but no value has been selected."</Description>
              <ToolId value="386" />
              <Expression>[#1] &amp;&amp; [#2] &amp;&amp; IsEmpty([#3])</Expression>
            </Action>
          </True>
        </NoCondition>
