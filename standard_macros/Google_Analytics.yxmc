      <Name>Google Analytics</Name>
      <Description>Query and download data from Google Analytics' Core Reporting API with multiple configuration options.</Description>
      <RootToolName>Google_Analytics.yxmc</RootToolName>
      <ToolVersion>1</ToolVersion>
      <ToolInDb value="False" />
      <CategoryName>Connectors</CategoryName>
      <SearchTags>google, social media, connectors, api, oauth, social, social data, ga</SearchTags>
      <Author>Garth Miles</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>2014</Copyright>
      <DescriptionLink actual="" displayed="" />
    </MetaInfo>
