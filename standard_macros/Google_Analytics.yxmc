              <Variable />
              <Replace value="True" />
              <ReplaceText>_________________________________CLIENT-ID_PLACEHOLDER________________________________________________________________________________________________</ReplaceText>
              <Destination>138/Data/r/c[1]</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="148" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>_________________________CLIENT-SECRET_PLACEHOLDER____________________________________________________________________________________________________</ReplaceText>
              <Destination>138/Data/r/c[2]</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="122" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>____________________end-date_placeholder____________________</ReplaceText>
              <Destination>256/Data/r/c[2]</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="121" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>____________________start-date_placeholder____________________</ReplaceText>
              <Destination>256/Data/r/c[1]</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="166" />
              <Expression>Switch([#1],'',
  'BOM', Replace([Destination], [Destination], Left(DateTimeFirstOfMonth(), 10)),
  'BOY', Replace([Destination], [Destination], Left(DateTimeTrim(DateTimeToday(),'year'), 10)),
  'P12M', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-12,'months'), 10)),  
  'P6M', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-6,'months'), 10)), 
  'P3M', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-3,'months'), 10)),
  'P2W', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-14,'days'), 10)),
  'P30D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-30,'days'), 10)),
  'P7D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-7,'days'), 10)),
  'P3D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-3,'days'), 10)),
  'P1D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-1,'days'), 10)),
  'BOD', Replace([Destination], [Destination], Left(DateTimeToday(), 10))  
)</Expression>
              <Destination>120/Data/r/c[1]</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="168" />
              <Expression>Replace([Destination], [Destination], Left(DateTimeToday(), 10))</Expression>
              <Destination>120/Data/r/c[2]</Destination>
              <Mode>Expression</Mode>
            </Action>
