    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Random % Sample</Name>
      <Description>Generate a random number or percentage of records passing through the data stream.</Description>
      <CategoryName>Preparation</CategoryName>
      <SearchTags>percent, records, random, seed, number, %, preparation category, n%, macro, sample</SearchTags>
      <Author>Alteryx</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>Alteryx, Inc.</Copyright>
      <DescriptionLink actual="" displayed="" />
      <Example>
        <Description>Open Example</Description>
        <File>02 Preparation\Random % Sample.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="22" />
          <Expression>[Percent]</Expression>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>NPercent</Description>
              <ToolId value="16" />
              <Mode>Simple</Mode>
              <Variable>NPercent</Variable>
              <Replace value="False" />
              <Destination>4/N</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="15" />
              <Expression>"NPercent"</Expression>
              <Destination>4/Mode</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="17" />
              <Expression>"First"</Expression>
              <Destination>4/Mode</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>NNumber</Description>
              <ToolId value="18" />
              <Mode>Simple</Mode>
              <Variable>NNumber</Variable>
              <Replace value="False" />
              <Destination>4/N</Destination>
            </Action>
          </False>
        </Condition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="23" />
          <Expression>[Deterministic]</Expression>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>Seed</Description>
              <ToolId value="20" />
              <Mode>Simple</Mode>
              <Variable>Seed</Variable>
              <Replace value="True" />
              <ReplaceText>MySeed</ReplaceText>
              <Destination>14/FormulaFields/FormulaField/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="19" />
              <Expression>"True"</Expression>
              <Destination>11/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="21" />
              <Expression>"False"</Expression>
              <Destination>11/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
          </False>
        </Condition>
      </Actions>
