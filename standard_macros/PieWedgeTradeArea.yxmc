      </GuiSettings>
      <Properties>
        <Configuration>
          <FormulaFields>
            <FormulaField field="WedgeWidth" type="Double" size="8" expression="(2*PI()/[NumWedges])" />
            <FormulaField field="OverSampleWidth" type="Double" size="8" expression="[WedgeWidth]*([OverSampleMultiplier]-1)" />
            <FormulaField field="FirstWedge" type="Int32" size="4" expression="Floor(([DirectionRad]-([OverSampleWidth]/2))/[WedgeWidth])" />
            <FormulaField field="LastWedge" type="Int32" size="4" expression="Floor(([DirectionRad]+([OverSampleWidth]/2))/[WedgeWidth])" />
            <FormulaField field="FirstWedge" type="Int32" size="4" expression="IIF([FirstWedge]&lt;0,[FirstWedge]+[NumWedges],[FirstWedge])" />
            <FormulaField field="LastWedge" type="Int32" size="4" expression="IIF([LastWedge]&gt;=[NumWedges],[LastWedge]-[NumWedges],[LastWedge])" />
          </FormulaFields>
        </Configuration>
