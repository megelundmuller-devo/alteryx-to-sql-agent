    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Multi-Field Binning</Name>
      <Description>Group multiple numeric fields into tiles or bins, especially for use in predictive analysis.</Description>
      <RootToolName>Multi-Field Binning</RootToolName>
      <ToolVersion>1</ToolVersion>
      <ToolInDb value="False" />
      <CategoryName>Preparation</CategoryName>
      <SearchTags>predictive, tile, thematic, data, bin, binning, numeric, macro, preparation category, data, table, group, assign</SearchTags>
      <Author>Alteryx, Inc.</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>Alteryx, Inc. 2013</Copyright>
      <DescriptionLink actual="" displayed="" />
      <Example>
        <Description>Open Example</Description>
        <File>02 Preparation\Multi-Field_Binning.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="False" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateSelect</Type>
              <Description>Fields to tile</Description>
              <ToolId value="309" />
              <Variable>Fields to tile</Variable>
              <SelectTool value="204" />
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'You must select at least one field for binning.'</Description>
              <ToolId value="308" />
              <Expression>ISEMPTY([Fields to tile])</Expression>
            </Action>
          </True>
        </NoCondition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="302" />
          <Expression>[EqualRecords]</Expression>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>EqualRecordsNumberOfTiles</Description>
              <ToolId value="304" />
              <Mode>Simple</Mode>
              <Variable>EqualRecordsNumberOfTiles</Variable>
              <Replace value="False" />
              <Destination>207/EqualRecords/NumTiles/@value</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="305" />
              <Expression>"False"</Expression>
              <Destination>215/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False />
        </Condition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="303" />
          <Expression>[EqualIntervals]</Expression>
          <True>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="306" />
              <Expression>"([Max_Value]-[Min_Value])/" + [EqualIntervalsNumberOfTiles]</Expression>
              <Destination>227/FormulaFields/FormulaField[@field='IntervalValue']/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="307" />
              <Expression>"True"</Expression>
              <Destination>215/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False />
        </Condition>
      </Actions>
