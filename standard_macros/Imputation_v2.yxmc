        <Node ToolID="254">
          <GuiSettings Plugin="AlteryxGuiToolkit.TextBox.TextBox">
            <Position x="748" y="95" width="326.8522" height="260.4639" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <Text>This macro was specifically created for the Alteryx suite of predictive analytic macros.  The macro gives the user to update specific values in a numeric data field (NULL, empty, or user specified values) with another selected value (mean, median, mode of remaining values, or another user specified value).

This is helpful as it allows the user to add values that would otherwise throw off the calculation of a specific field.  

For example, let's say you have a row of 10 fields, but 3 of them are NULL.  The average of the remaining values is 6, so you populate the remaining fields with 6 so as to not throw off the average of the remaining values.</Text>
              <Font name="Microsoft Sans Serif" size="9.75" style="0" />
              <TextColor name="Black" />
              <FillColor name="White" />
              <Shape shape="0" />
              <Justification Justification="0" />
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText />
              <Left value="False" />
            </Annotation>
          </Properties>
        </Node>
      </ChildNodes>
    </Node>
