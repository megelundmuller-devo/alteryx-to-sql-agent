    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Weighted Average</Name>
      <Description>Calculate the weighted average of a set of values where some records are configured to contribute more than others.</Description>
      <CategoryName>Transform</CategoryName>
      <SearchTags>summary, summarize, transpose, transpose category, macro, average, data, weight, group</SearchTags>
      <Author />
      <Company />
      <Copyright />
      <DescriptionLink actual="" displayed="" />
      <Example>
        <Description>Open Example</Description>
        <File>05 Transform\WeightedAverage.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateRawXml</Type>
              <Description />
              <ToolId value="9" />
              <Expression>if !IsEmpty([GroupFields]) then
'&lt;SummarizeField field="' + [GroupFields] + '" action="GroupBy"/&gt;'
else
''
endif 
+
'      &lt;SummarizeField field="' + [Weight] + '" action="Sum" rename="__Sum_Weight" /&gt;
      &lt;SummarizeField field="__WeightedValue" action="Sum" rename="__Sum___WeightedValue" /&gt;'</Expression>
              <Destination>2/SummarizeFields</Destination>
              <OuterXml value="False" />
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>Value</Description>
              <ToolId value="10" />
              <Mode>Simple</Mode>
              <Variable>Value</Variable>
              <Replace value="True" />
              <ReplaceText>Value</ReplaceText>
              <Destination>3/FormulaFields/FormulaField/@expression</Destination>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description />
              <ToolId value="11" />
              <Expression>!(!IsEmpty([Value]))</Expression>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>Weight</Description>
              <ToolId value="12" />
              <Mode>Simple</Mode>
              <Variable>Weight</Variable>
              <Replace value="True" />
              <ReplaceText>Weight</ReplaceText>
              <Destination>3/FormulaFields/FormulaField/@expression</Destination>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description />
              <ToolId value="13" />
              <Expression>!(!IsEmpty([Weight]))</Expression>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>OutputFieldName</Description>
              <ToolId value="14" />
              <Mode>Simple</Mode>
              <Variable>OutputFieldName</Variable>
              <Replace value="False" />
              <Destination>4/FormulaFields/FormulaField/@field</Destination>
