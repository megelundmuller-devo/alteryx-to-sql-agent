        <Name>OwnLogo</Name>
        <Value />
        <IsNumeric value="False" />
      </Constant>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>IncludeImage</Name>
        <Value />
        <IsNumeric value="False" />
      </Constant>
    </Constants>
    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Report Header</Name>
      <Description>Add a header to a report for output via the Render tool.</Description>
      <CategoryName>Reporting</CategoryName>
      <SearchTags>report, presentation, macro, header, top, title, head, reporting category, logo, Mike Akey</SearchTags>
      <Author>Alteryx, Inc.</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>Alteryx, Inc. 2012</Copyright>
      <DescriptionLink actual="" displayed="" />
	    <RootToolName>Report Header</RootToolName>
      <ToolVersion>1</ToolVersion>
	  <Example>
        <Description>Open Example</Description>
        <File>07 Reporting\Report_Header.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>DateFormat</Description>
              <ToolId value="46" />
              <Mode>Simple</Mode>
              <Variable>DateFormat</Variable>
              <Replace value="False" />
              <Destination>1/Value</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>HeaderText</Description>
              <ToolId value="47" />
              <Mode>Simple</Mode>
              <Variable>HeaderText</Variable>
              <Replace value="True" />
              <ReplaceText>Report Header Text</ReplaceText>
              <Destination>2/RichTextString</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="48" />
              <Expression>IF [IncludeDate] == 'True' THEN "[DateTimeNow]"
ELSE "''" ENDIF</Expression>
              <Destination>7/FormulaFields/FormulaField/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
        </NoCondition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="52" />
          <Expression>[IncludeImage] and [OwnLogo]</Expression>
          <True>
            <Action>
              <Type>UpdateRawXml</Type>
              <Description />
              <ToolId value="49" />
              <Expression>'  &lt;ImageMode&gt;File&lt;/ImageMode&gt;
  &lt;Filename&gt;' + 
iif(FileExists([Engine.ModuleDirectory]+[ImageFile]), [Engine.ModuleDirectory]+[ImageFile],[ImageFile]) 
+ '&lt;/Filename&gt;
  &lt;ModifyFilename value="False" /&gt;
  &lt;StopIfNotFound value="True" /&gt;
  &lt;ImageStyle FixedWidth="true" ImageWidth="150" ShowBorder="false" BorderWidth="1" BorderColor="#000000" /&gt;'</Expression>
              <Destination>3</Destination>
              <OuterXml value="False" />
            </Action>
          </True>
          <False />
        </Condition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="53" />
          <Expression>[IncludeImage]</Expression>
          <True>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="50" />
              <Expression>'True'</Expression>
              <Destination>18/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="51" />
              <Expression>'False'</Expression>
              <Destination>18/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
          </False>
        </Condition>
      </Actions>
      <Questions>
        <Question>
          <Type>Tab</Type>
          <Description>Configuration</Description>
          <Name>Tab (63)</Name>
          <ToolId value="63" />
          <Questions>
            <Question>
              <Type>Label</Type>
              <Description>The Report Header macro will append the created header to your supplied data, this new field can then be used in a Render tool as the Header for your report.</Description>
              <Name>Label (54)</Name>
              <ToolId value="54" />
            </Question>
            <Question>
              <Type>TextBox</Type>
              <Description>Enter the report title:</Description>
              <Name>HeaderText</Name>
              <ToolId value="55" />
              <Default>Alteryx Report</Default>
              <Password value="False" />
              <Multiline value="False" />
              <Hidden value="False" />
            </Question>
            <Question>
              <Type>BooleanGroup</Type>
              <Description>Include the date in your report header.</Description>
              <Name>IncludeDate</Name>
              <ToolId value="57" />
              <Questions>
                <Question>
                  <Type>ListBox</Type>
                  <Description>Specify the date format:</Description>
                  <Name>DateFormat</Name>
                  <ToolId value="56" />
                  <Multiple value="False" />
                  <Default>Month dd, yyyy</Default>
                  <Mode>Manual</Mode>
                  <Manual_Values><![CDATA[yyyy-MM-dd
yyyyMMdd	
MM/dd/yy
MM/dd/yyyy
MM-dd-yy
MM-dd-yyyy
Month dd, yyyy
Month, yyyy        
Mon dd           
dd/MM/yy
dd/MM/yyyy
dd-MM-yy
dd-MM-yyyy
dd-Mon.-yy
dy., Month dd, yyyy
day, dd Month, yyyy
dd Month, yyyy
yyyy-MM-dd hhːmmːss:yyyy-MM-dd hh:mm:ss
MM/dd/yyyy hhːmmːss:MM/dd/yyyy hh:mm:ss
MM/dd/yy hhːmmːss:MM/dd/yy hh:mm:ss
dd/MM/yyyy hhːmmːss:dd/MM/yyyy hh:mm:ss
dd/MM/yy hhːmmːss:dd/MM/yy hh:mm:ss
]]></Manual_Values>
                </Question>
              </Questions>
              <Default value="True" />
              <Collapsable value="False" />
            </Question>
            <Question>
              <Type>BooleanGroup</Type>
              <Description>Include an image (logo) on your header.</Description>
              <Name>IncludeImage</Name>
              <ToolId value="62" />
              <Questions>
                <Question>
                  <Type>RadioGroup</Type>
                  <Description>Use the Alteryx logo</Description>
                  <Name>AlteryxLogo</Name>
                  <ToolId value="58" />
                  <Questions />
                  <Default value="True" />
                  <Collapsable value="False" />
                </Question>
                <Question>
                  <Type>RadioGroup</Type>
                  <Description>Specify custom image:</Description>
                  <Name>OwnLogo</Name>
                  <ToolId value="61" />
                  <Questions>
                    <Question>
                      <Type>FileBrowse</Type>
                      <Description>Browse to the image to use in the report header:</Description>
                      <Name>ImageFile</Name>
                      <ToolId value="59" />
                      <SaveAs value="False" />
                      <Mode>FileSpec</Mode>
                      <FileSpec>Image Files (*.png, *.gif, *jpg)|*.png;*.gif;*.jpg|All Files (*.*)|*.*</FileSpec>
                    </Question>
                    <Question>
                      <Type>Label</Type>
                      <Description>The size of the Alteryx logo is 150 by 55 (W x H) pixels, if you use an image of a different size or ratio, you may encounter layout issues. You may need to resize your image outside of Alteryx.</Description>
                      <Name>Label (60)</Name>
                      <ToolId value="60" />
                    </Question>
                  </Questions>
                  <Default value="False" />
                  <Collapsable value="False" />
                </Question>
              </Questions>
              <Default value="True" />
              <Collapsable value="False" />
            </Question>
            <Question>
              <Type>MacroOutput</Type>
              <Description>Output13</Description>
              <Name>Output13</Name>
              <ToolId value="66" />
            </Question>
          </Questions>
        </Question>
        <Question>
          <Type>Tab</Type>
          <Description>Report Layout</Description>
          <Name>Tab (64)</Name>
          <ToolId value="64" />
          <Questions>
            <Question>
              <Type>MacroInput</Type>
              <Description>Report Layout</Description>
              <Name>Report Layout</Name>
              <ToolId value="65" />
            </Question>
          </Questions>
        </Question>
      </Questions>
      <ModuleType>Macro</ModuleType>
