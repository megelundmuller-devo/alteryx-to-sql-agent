    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Imputation</Name>
      <Description>Update specific values in a numeric data field with another selected value. Useful for replacing NULL() values.</Description>
      <RootToolName>Imputation</RootToolName>
      <ToolVersion>2</ToolVersion>
      <ToolInDb value="False" />
      <CategoryName>Preparation</CategoryName>
      <SearchTags>impute, imputation, replace, null, empty, value, summarize, average, median, mode, preparation category, predictive, macro, values, substitute, zero, -99, data prep</SearchTags>
      <Author>Garth Miles</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>2015</Copyright>
      <DescriptionLink actual="" displayed="" />
      <Example>
        <Description>Open Example</Description>
        <File>02 Preparation\Imputation.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="18" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'</ReplaceText>
              <Destination>150/Expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="35" />
              <Expression><![CDATA[IF 
[#1] THEN 
  'IsNull([Value])' 
ELSE 
  '[Value] == ' + [#3]
ENDIF
]]></Expression>
              <Destination>153/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="52" />
              <Expression>IF 
[#1] THEN 
  "[Name] == '_mean' &amp;&amp; !IsEmpty([Value])"
ELSEIF 
[#2] THEN 
  "[Name] == '_median' &amp;&amp; !IsEmpty([Value])"
ELSEIF 
[#3] THEN 
  "[Name] == '_mode' &amp;&amp; !IsEmpty([Value])" 
ELSEIF 
[#4] THEN 
  "[Name] == '_user' &amp;&amp; !IsEmpty([Value])"
ELSE 
  "" 
ENDIF</Expression>
              <Destination>158/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="78" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="False" />
              <Destination>159/FormulaFields/FormulaField/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="85" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'</ReplaceText>
              <Destination>163/Expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="106" />
              <Expression>IF 
[#1] &amp;&amp; [#2] THEN 
  "!REGEX_Match([Name], '^\_.*')" 
ELSEIF 
[#1] &amp;&amp; ![#2] THEN 
  "!REGEX_Match([Name], '(^\_.*|^.*?(?:_Imp).*)')" 
ELSEIF 
![#1] &amp;&amp; [#2] THEN 
  "!REGEX_Match([Name], '(^\_.*|^.*?(?:_Ind).*)')" 
ELSE 
  "!REGEX_Match([Name], '(^_(?:rows|RowCount|runtimeID))|.*(_I(?:mp|nd)).*')" 
ENDIF</Expression>
              <Destination>189/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="108" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="False" />
              <Destination>169/DetourRight/@value</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="139" />
              <Expression>IF 
[#1] THEN 
  "[Name] + '_ImputedValue'" 
ELSE 
  "[Name]" 
ENDIF</Expression>
              <Destination>171/FormulaFields/FormulaField/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="200" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'</ReplaceText>
              <Destination>177/FormulaFields/FormulaField/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description />
              <ToolId value="201" />
              <Mode>Simple</Mode>
              <Variable />
              <Replace value="True" />
              <ReplaceText>'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J'</ReplaceText>
              <Destination>173/FormulaFields/FormulaField/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="203" />
              <Expression>IF 
[#1] &amp;&amp; [#2] THEN 
  "!REGEX_Match([Name], '^\_.*')" 
ELSEIF 
[#1] &amp;&amp; ![#2] THEN 
  "!REGEX_Match([Name], '(^\_.*|^.*?(?:_Imp).*)')" 
ELSEIF 
![#1] &amp;&amp; [#2] THEN 
  "!REGEX_Match([Name], '(^\_.*|^.*?(?:_Ind).*)')" 
ELSE 
  "!REGEX_Match([Name], '(^_(?:rows|RowCount|runtimeID))|.*(_I(?:mp|nd)).*')"
ENDIF</Expression>
              <Destination>202/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
        </NoCondition>
      </Actions>
