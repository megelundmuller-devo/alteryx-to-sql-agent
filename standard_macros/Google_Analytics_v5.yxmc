            <Question>
              <Type>LabelGroup</Type>
              <Description />
              <Name>LabelGroup (503)</Name>
              <ToolId value="503" />
              <Questions>
                <Question>
                  <Type>RadioGroup</Type>
                  <Description>Update Mode</Description>
                  <Name>update_mode</Name>
                  <ToolId value="463" />
                  <Questions>
                    <Question>
                      <Type>Label</Type>
                      <Description>Options specific to the credentials provided will be pulled from Google Analytics and updated in the query options below. (For example, custom metrics, dimensions, and segments.)</Description>
                      <Name>Label (466)</Name>
                      <ToolId value="466" />
                    </Question>
                    <Question>
                      <Type>BooleanGroup</Type>
                      <Description>Reset to default</Description>
                      <Name>Check Box (571)</Name>
                      <ToolId value="571" />
                      <Questions />
                      <Default value="False" />
                      <Collapsable value="False" />
                    </Question>
                    <Question>
                      <Type>Label</Type>
                      <Description>*** WARNING: Run this macro as a standalone process, or disable any downstream tools to prevent possible errors when using this feature ***</Description>
                      <Name>Label (544)</Name>
                      <ToolId value="544" />
                    </Question>
                  </Questions>
                  <Default value="True" />
                  <Collapsable value="True" />
                </Question>
                <Question>
                  <Type>RadioGroup</Type>
                  <Description>Query mode</Description>
                  <Name>Radio Button (465)</Name>
                  <ToolId value="465" />
                  <Questions>
                    <Question>
                      <Type>LabelGroup</Type>
                      <Description>Required</Description>
                      <Name>LabelGroup (16)</Name>
                      <ToolId value="16" />
                      <Questions>
                        <Question>
                          <Type>LabelGroup</Type>
                          <Description>Profile (view) ID</Description>
                          <Name>LabelGroup (514)</Name>
                          <ToolId value="514" />
                          <Questions>
                            <Question>
                              <Type>RadioGroup</Type>
                              <Description>Select from Drop Down:</Description>
                              <Name>Radio Button (512)</Name>
                              <ToolId value="512" />
                              <Questions>
                                <Question>
                                  <Type>Tree</Type>
                                  <Description>Select a profile</Description>
                                  <Name>Tree (575)</Name>
                                  <ToolId value="575" />
                                  <Mode>CustomXml</Mode>
                                  <Xml_Path>Supporting_Macros\GoogleAnalytics.PROFILES.xml</Xml_Path>
                                  <Filter />
                                  <Filter_ShowFullParentage value="False" />
                                  <SingleSelect value="True" />
                                  <Height_NumLines value="6" />
                                </Question>
                              </Questions>
                              <Default value="True" />
                              <Collapsable value="True" />
                            </Question>
                            <Question>
                              <Type>RadioGroup</Type>
                              <Description>Manual Entry:</Description>
                              <Name>Radio Button (513)</Name>
                              <ToolId value="513" />
                              <Questions>
                                <Question>
                                  <Type>TextBox</Type>
