    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Map Legend Splitter</Name>
      <Description>Split the legend from the Report Map tool into its component parts for customization by other tools. (Generally recombined by the Map Legend Builder.)</Description>
      <CategoryName>Reporting</CategoryName>
      <SearchTags>report, presentation, spatial, map, legend, macro, table, custom, splitter, reporting category, Mike Akey</SearchTags>
      <Author>Adam Riley</Author>
      <Company>Alteryx</Company>
      <Copyright>Alteryx, Inc.</Copyright>
      <DescriptionLink actual="" displayed="" />
	  <Example>
        <Description>Open Example</Description>
        <File>07 Reporting\Map_Legend_Splitter_Builder.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>Legend Field</Description>
              <ToolId value="71" />
              <Mode>Simple</Mode>
              <Variable>Legend Field</Variable>
              <Replace value="True" />
              <ReplaceText>Legend</ReplaceText>
              <Destination>13/FormulaFields/FormulaField/@expression</Destination>
            </Action>
          </True>
        </NoCondition>
      </Actions>
