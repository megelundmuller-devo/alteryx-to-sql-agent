            <Position x="1069" y="2005" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField field="Name" type="String" size="11" expression="IF [Name] IN ('filters_metrics', 'filters_dimensions') THEN &#xA;  'filters' &#xA;ELSE &#xA;  [Name] &#xA;ENDIF" />
                <FormulaField field="Name" type="String" size="11" expression="ReplaceChar([Name], '_', '-')" />
                <FormulaField field="Value" type="V_WString" size="1073741823" expression="REGEX_Replace([Value], '\n', '\,')" />
                <FormulaField field="Value" type="V_WString" size="1073741823" expression="IF [Name] == 'ids' THEN &#xA;  'ga:' + [Value] &#xA;ELSE &#xA;  [Value] &#xA;ENDIF" />
                <FormulaField field="Query" type="V_WString" size="1500" expression="[Name] + '=' + [Value]" />
                <FormulaField field="Segment" type="V_String" size="64" expression="'Query'" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="1">
              <Name />
              <AnnotationText>Constructs 
query param 
parts</AnnotationText>
              <DefaultAnnotationText>Name=IF [Name] IN ('filters_metrics', 'filters_dimensions') T...
Name=ReplaceChar([Name], '_', '-')
Value=REGEX_Replace([Value], '\n', '\,')
...</DefaultAnnotationText>
              <Left value="True" />
            </Annotation>
            <MetaInfo connection="Output">
              <RecordInfo>
                <Field name="Name" size="11" source="Formula: ReplaceChar([Name], '_', '-')" type="String" />
                <Field name="Value" size="1073741823" source="Formula: IF [Name] == 'ids' THEN &#xA;  'ga:' + [Value] &#xA;ELSE &#xA;  [Value] &#xA;ENDIF" type="V_WString" />
                <Field name="Query" size="1500" source="Formula: [Name] + '=' + [Value]" type="V_WString" />
                <Field name="Segment" size="64" source="Formula: 'Query'" type="V_String" />
              </RecordInfo>
            </MetaInfo>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
