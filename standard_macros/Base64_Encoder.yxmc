          <Properties>
            <Configuration>
              <Text>calculate the value of each binary digit using binary counting rules.
***see ADD'L NOTES for more information***</Text>
              <Font name="Segoe UI" size="8.25" style="0" />
              <TextColor name="White" />
              <FillColor r="111" g="111" b="111" />
