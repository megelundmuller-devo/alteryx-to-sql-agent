  <Properties>
    <Memory default="True" />
    <GlobalRecordLimit value="0" />
    <TempFiles default="True" />
    <Annotation on="False" includeToolName="False" />
    <ConvErrorLimit value="10" />
    <ConvErrorLimit_Stop value="False" />
    <CancelOnError value="False" />
    <DisableBrowse value="False" />
    <DisableAllOutput value="False" />
    <ShowAllMacroMessages value="False" />
    <ShowConnectionStatusIsOn value="True" />
    <ShowConnectionStatusOnlyWhenRunning value="True" />
    <ZoomLevel value="0" />
    <LayoutType>Horizontal</LayoutType>
    <Constants>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>GridSize</Name>
        <Value />
        <IsNumeric value="True" />
      </Constant>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>MaxDistance</Name>
        <Value />
        <IsNumeric value="True" />
      </Constant>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>DecayFunction</Name>
        <Value />
        <IsNumeric value="False" />
      </Constant>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>SmoothResults</Name>
        <Value />
        <IsNumeric value="False" />
      </Constant>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>OuputStacked</Name>
        <Value />
        <IsNumeric value="False" />
      </Constant>
      <Constant>
        <Namespace>Question</Namespace>
        <Name>OutputDonuts</Name>
        <Value />
        <IsNumeric value="False" />
      </Constant>
    </Constants>
    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Heat Map</Name>
      <Description>Generate polygons representing different levels of "heat" (e.g. demand) in a given area, based on individual records (e.g. customers)</Description>
      <RootToolName />
      <ToolVersion />
      <ToolInDb value="False" />
      <CategoryName>Spatial</CategoryName>
      <SearchTags>heat, polygon, cell, grid, thematic, distance, decay, smooth, map, demand, macro</SearchTags>
      <Author />
      <Company />
      <Copyright />
      <DescriptionLink actual="" displayed="" />
      <Example>
        <Description>Open Example</Description>
        <File>09 Spatial\Heat_Map.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>GridSize</Description>
              <ToolId value="515" />
              <Mode>Simple</Mode>
              <Variable>GridSize</Variable>
              <Replace value="False" />
              <Destination>133/FormulaFields/FormulaField[@field='GridSize_Miles']/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>MaxDistance</Description>
              <ToolId value="516" />
              <Mode>Simple</Mode>
              <Variable>MaxDistance</Variable>
              <Replace value="False" />
              <Destination>133/FormulaFields/FormulaField[@field='MaxDistance']/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>DecayFunction</Description>
              <ToolId value="517" />
              <Mode>Simple</Mode>
              <Variable>DecayFunction</Variable>
              <Replace value="False" />
              <Destination>156/FormulaFields/FormulaField[@field='HeatFraction']/@expression</Destination>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>SmoothResults</Description>
              <ToolId value="518" />
              <Mode>Simple</Mode>
              <Variable>SmoothResults</Variable>
              <Replace value="False" />
              <Destination>275/DetourRight/@value</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="519" />
              <Expression>[OutputDonuts]&amp;&amp;![SmoothResults]</Expression>
              <Destination>470/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>OutputDonuts</Description>
              <ToolId value="520" />
              <Mode>Simple</Mode>
              <Variable>OutputDonuts</Variable>
              <Replace value="False" />
              <Destination>277/DetourRight/@value</Destination>
            </Action>
          </True>
        </NoCondition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="525" />
          <Expression>[SmoothResults]</Expression>
          <True>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="521" />
              <Expression>0.35 * ToNumber( [GridSize])</Expression>
              <Destination>505/Threshold</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>GridSize</Description>
              <ToolId value="522" />
              <Mode>Simple</Mode>
              <Variable>GridSize</Variable>
              <Replace value="False" />
              <Destination>506/MaximumRadius</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="523" />
              <Expression>0.35 * ToNumber( [GridSize])</Expression>
              <Destination>507/Threshold</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="524" />
              <Expression>0.5 * ToNumber( [GridSize])</Expression>
              <Destination>508/MaximumRadius</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False />
        </Condition>
      </Actions>
      <Questions>
        <Question>
          <Type>Tab</Type>
          <Description>Questions</Description>
          <Name>Tab (535)</Name>
          <ToolId value="535" />
          <Questions>
            <Question>
              <Type>Label</Type>
              <Description>A smaller grid size will provide a more detailed map, but take longer to run.</Description>
              <Name>Label (526)</Name>
              <ToolId value="526" />
            </Question>
            <Question>
              <Type>Label</Type>
              <Description>The cell containing a source point gets the full Heat value for that point; Grid Cells more than the Max Distance away get no heat.  Cells in between get a fraction of the heat determined by the decay function.  The decay function should return a value in the range [0-1] and can assume DistanceMiles is in the range (0-MaxDistance].</Description>
              <Name>Label (527)</Name>
              <ToolId value="527" />
            </Question>
            <Question>
              <Type>NumericUpDown</Type>
              <Description>Grid Size</Description>
              <Name>GridSize</Name>
              <ToolId value="528" />
              <Minimum value="0" />
              <Maximum value="100" />
              <Increment value="1" />
              <Default value="1" />
              <Decimals value="1" />
            </Question>
            <Question>
              <Type>NumericUpDown</Type>
              <Description>Maximum Distance</Description>
              <Name>MaxDistance</Name>
              <ToolId value="529" />
              <Minimum value="0" />
              <Maximum value="100" />
              <Increment value="1" />
              <Default value="10" />
              <Decimals value="1" />
            </Question>
            <Question>
              <Type>TextBox</Type>
              <Description>Decay Function</Description>
              <Name>DecayFunction</Name>
              <ToolId value="530" />
              <Default>1 - [Distance]/[MaxDistance]</Default>
              <Password value="False" />
              <Multiline value="False" />
              <Hidden value="False" />
            </Question>
            <Question>
              <Type>BooleanGroup</Type>
              <Description>Smooth Results</Description>
              <Name>SmoothResults</Name>
              <ToolId value="531" />
              <Questions />
              <Default value="True" />
              <Collapsable value="False" />
            </Question>
            <Question>
              <Type>LabelGroup</Type>
              <Description>Output Type</Description>
              <Name>LabelGroup (534)</Name>
              <ToolId value="534" />
              <Questions>
                <Question>
                  <Type>RadioGroup</Type>
                  <Description>Stacked</Description>
                  <Name>OuputStacked</Name>
                  <ToolId value="532" />
                  <Questions />
                  <Default value="True" />
                  <Collapsable value="False" />
                </Question>
                <Question>
                  <Type>RadioGroup</Type>
                  <Description>Donuts</Description>
                  <Name>OutputDonuts</Name>
                  <ToolId value="533" />
                  <Questions />
                  <Default value="False" />
                  <Collapsable value="False" />
                </Question>
              </Questions>
            </Question>
            <Question>
              <Type>MacroOutput</Type>
              <Description>Output80</Description>
              <Name>Output80</Name>
              <ToolId value="538" />
            </Question>
          </Questions>
        </Question>
        <Question>
          <Type>Tab</Type>
          <Description>Input</Description>
          <Name>Tab (536)</Name>
          <ToolId value="536" />
          <Questions>
            <Question>
              <Type>MacroInput</Type>
              <Description>Input</Description>
              <Name>Input</Name>
              <ToolId value="537" />
            </Question>
          </Questions>
        </Question>
      </Questions>
