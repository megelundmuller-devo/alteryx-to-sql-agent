              <Destination>196/Data/r/c</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="222" />
              <Expression>IIF([#1], 'False', 'True')</Expression>
              <Destination>220/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="223" />
              <Expression>IIF([#1], 'False', 'True')</Expression>
              <Destination>219/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="225" />
              <Expression>IIF([#1], 'False', 'True')</Expression>
              <Destination>213/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="228" />
              <Expression>IF 
![#1] || [#2] THEN 
  'True'
ELSE 
  [Destination] 
ENDIF</Expression>
              <Destination>221/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="231" />
              <Expression>IIF([#1], 'False', 'True')</Expression>
              <Destination>218/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'Client ID, Client Secret, and Refresh Token are required to retrieve data.'</Description>
              <ToolId value="351" />
              <Expression>// needed no matter what (regardless of query mode)

IsEmpty([#2]) &amp;&amp; IsEmpty([#3]) &amp;&amp; IsEmpty([#4])</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'The Profile (View) ID and Metric fields are required to retrieve data.'</Description>
              <ToolId value="371" />
              <Expression>[#3] // standard query mode
&amp;&amp; (
	  (IsEmpty([#1]) &amp;&amp; [#5] ) // profile manual entry
	||(IsEmpty([#4]) &amp;&amp; [#6] )  // profile dropdown
	|| IsEmpty([#2]) // metrics
)</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'A Start and End date are required to retrieve data.'</Description>
              <ToolId value="373" />
              <Expression>[#4] // standard query mode
&amp;&amp; (
	[#1] &amp;&amp; IsEmpty([#2]) || [#1] &amp;&amp; IsEmpty([#3])
)</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>"The 'Dimensions' option is enabled but none have been selected."</Description>
              <ToolId value="384" />
              <Expression>[#4] // standard query mode
&amp;&amp; (
	[#1] &amp;&amp; [#2] &amp;&amp; IsEmpty([#3])
)</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'Too many Dimensions (more than 7) have been added.'</Description>
              <ToolId value="385" />
              <Expression>[#4] // standard query mode
&amp;&amp; (
	[#1] &amp;&amp; [#2] &amp;&amp; REGEX_CountMatches([#3], '\n') + 1 &gt; 7
)</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>"The 'Segments' option is enabled but no value has been selected."</Description>
              <ToolId value="386" />
              <Expression>[#4] // standard query mode
&amp;&amp; (
	[#1] &amp;&amp; [#2] &amp;&amp; IsEmpty([#3])
)</Expression>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="214" />
              <Expression>IF 
[#1] &amp;&amp; [#2] THEN 
  [Destination] 
ELSE 
  'True' 
ENDIF</Expression>
              <Destination>213/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="130" />
              <Expression>IF 
[#3] &amp;&amp; ToNumber([#1]) == 1 THEN 
  ToNumber([#1]) 
ELSEIF 
[#3] &amp;&amp; ToNumber([#1]) &gt; 1 THEN 
  (ToNumber([#1]) * ToNumber([#2])) + 1 
ELSE 
  ToNumber([#1]) * 1000
ENDIF</Expression>
              <Destination>126/Data/r/c</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="212" />
              <Expression>IF 
[#1] &amp;&amp; [#2] THEN 
  [Destination] + " + '&amp;max-results=" + [#3] + "'" 
ELSE 
  [Destination] 
ENDIF</Expression>
              <Destination>277/FormulaFields/FormulaField/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="458" />
              <Expression>![#2]</Expression>
              <Destination>449/DetourRight/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>'Too many Metrics (more than 10) have been added.'</Description>
              <ToolId value="504" />
              <Expression>[#1] // standard query mode
&amp;&amp; (
	REGEX_CountMatches([#2], ':') &gt; 10	 // using colon since each metric id begins "ga:"
)</Expression>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="508" />
              <Expression>[#1]</Expression>
              <Destination>346/Disabled/@value</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>Dynamic</Type>
              <Description />
              <ToolId value="520" />
              <Expression>{{INPUT}}</Expression>
              <Destination>507/Disabled/@value</Destination>
              <Mapping>Enable/Disable Container from Question</Mapping>
              <Mode>Expression</Mode>
              <DynamicConfiguration />
              <DefaultConfiguration value="True" />
            </Action>
            <Action>
              <Type>Dynamic</Type>
              <Description />
              <ToolId value="521" />
              <Expression>{{INPUT}}</Expression>
              <Destination>519/Disabled/@value</Destination>
              <Mapping>Enable/Disable Container from Question</Mapping>
              <Mode>Expression</Mode>
              <DynamicConfiguration />
              <DefaultConfiguration value="True" />
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>Please uncheck User-Specific metrics that are not for the specified Profile (View) ID.</Description>
              <ToolId value="527" />
              <Expression>[#1] &amp;&amp; (REGEX_CountMatches([#6], "\{\d+\}") &gt; REGEX_CountMatches([#6], "\{" + (IIF([#2], [#3], "") + IIF([#4], [#5], ""))	+ "\}"))</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>Please uncheck User-Specific dimensions that are not for the specified Profile (View) ID.</Description>
              <ToolId value="531" />
              <Expression>[#1] &amp;&amp; (

	REGEX_CountMatches([#6], "\{\d+\}")				// number of custom params selected
	&gt; 
	REGEX_CountMatches([#6], 
		"\{" +
			(IIF([#2], [#3], "") + IIF([#4], [#5], "")) // the selected viewID
		+ "\}"
	)
)</Expression>
            </Action>
            <Action>
              <Type>Error</Type>
              <Description>Please uncheck User-Specific segments that are not for the specified Profile (View) ID.</Description>
              <ToolId value="532" />
              <Expression>[#1] &amp;&amp; (

	REGEX_CountMatches([#6], "\{\d+\}")				// number of custom params selected
	&gt; 
	REGEX_CountMatches([#6], 
		"\{" +
			(IIF([#2], [#3], "") + IIF([#4], [#5], "")) // the selected viewID
		+ "\}"
	)
)</Expression>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="554" />
              <Expression><![CDATA[IF 
[#1] THEN 
Switch([#2],'',
  'BOM', Replace([Destination], [Destination], Left(DateTimeFirstOfMonth(), 10)),
  'BOY', Replace([Destination], [Destination], Left(DateTimeTrim(DateTimeToday(),'year'), 10)),
  'P12M', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-12,'months'), 10)),  
  'P6M', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-6,'months'), 10)), 
  'P3M', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-3,'months'), 10)),
  'P2W', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-14,'days'), 10)),
  'P30D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-30,'days'), 10)),
  'P7D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-7,'days'), 10)),
  'P3D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-3,'days'), 10)),
  'P1D', Replace([Destination], [Destination], Left(DateTimeAdd(DateTimeToday(),-1,'days'), 10)),
  'BOD', Replace([Destination], [Destination], Left(DateTimeToday(), 10))  
)
ELSEIF 
[#3] THEN 
  [#4] 
ELSEIF 
[#5] THEN 
  [#6] 
ELSE 
  '' 
ENDIF
]]></Expression>
              <Destination>553/Value[@name='start_date']</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="555" />
              <Expression>IF 
[#1] THEN 
  Replace([Destination], [Destination], Left(DateTimeToday(), 10)) 
ELSEIF 
[#3] THEN 
  [#4] 
ELSEIF 
[#5] THEN 
  [#6] 
ELSE 
