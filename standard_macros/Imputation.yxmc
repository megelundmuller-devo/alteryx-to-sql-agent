    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Imputation</Name>
      <Description><![CDATA[Update specific values in a numeric data field with another selected value. Useful for replacing NULL() values.

]]></Description>
      <RootToolName>Imputation</RootToolName>
      <ToolVersion>1</ToolVersion>
      <ToolInDb value="False" />
      <CategoryName>Preparation</CategoryName>
      <SearchTags>impute, imputation, replace, null, empty, value, summarize, average, median, mode, preparation category, predictive, macro, values, substitute, zero, -99, data prep</SearchTags>
      <Author>Alteryx</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>©2013 Alteryx, Inc. All rights reserved.</Copyright>
      <DescriptionLink actual="" displayed="" />
      <Example>
        <Description>Open Example</Description>
        <File>02 Preparation\Imputation.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateSelect</Type>
              <Description>dropdown Select Incoming Fields</Description>
              <ToolId value="183" />
              <Variable>dropdown Select Incoming Fields</Variable>
              <SelectTool value="140" />
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="184" />
              <Expression>IF [radio Null Value]
THEN '"ISNULL([_CurrentField_])"'
ELSE '"[_CurrentField_]==(' + TOSTRING([updown User Replace Value]) + ')"'
ENDIF</Expression>
              <Destination>108/FormulaFields/FormulaField[@field='Expression']/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="185" />
              <Expression>IF [radio Null Value]
THEN '"!ISNULL([_CurrentField_])"'
ELSE '"[_CurrentField_]!=(' + TOSTRING([updown User Replace Value]) + ')"'
ENDIF</Expression>
              <Destination>112/FormulaFields/FormulaField[@field='Expression']/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="186" />
              <Expression>IF [radio Mean]
THEN "Avg"
ELSEIF [radio Median]
THEN "Median"
ELSEIF [radio Mode]
THEN "Mode"
ELSE "First"
ENDIF</Expression>
              <Destination>148/SummarizeFields/SummarizeField[@field='Value']/@action</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="187" />
              <Expression>IIF([radio User Specified Replace With Value],[updown User Replace With Value],"[Value]")</Expression>
              <Destination>152/FormulaFields/FormulaField/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValue</Type>
              <Description>checkbox Impute Indicator</Description>
              <ToolId value="188" />
              <Mode>Simple</Mode>
              <Variable>checkbox Impute Indicator</Variable>
              <Replace value="False" />
              <Destination>161/DetourRight/@value</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="189" />
              <Expression><![CDATA[IF [radio Null Value]
THEN
"!ISNULL([Value])"
ELSEIF
[radio User Specified Replace From Value]
Then
"[Value]!=[Question.updown User Replace Value]"
ELSE
1==1
ENDIF
]]></Expression>
              <Destination>178/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
        </NoCondition>
        <Condition>
          <Type>Condition</Type>
          <Description />
          <ToolId value="194" />
          <Expression>[checkbox Imputed Values Separate Field]</Expression>
          <True>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="190" />
              <Expression>"[Name]"</Expression>
              <Destination>145/FormulaFields/FormulaField/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="191" />
              <Expression>'[_CurrentField_] + "_ImputedValue"'</Expression>
              <Destination>165/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
          <False>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="192" />
              <Expression>'[Name] + "_DropThisField_"'</Expression>
              <Destination>145/FormulaFields/FormulaField/@expression</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="193" />
              <Expression>'[_CurrentField_]'</Expression>
              <Destination>165/Expression</Destination>
              <Mode>Expression</Mode>
            </Action>
          </False>
        </Condition>
      </Actions>
      <Questions>
        <Question>
          <Type>Tab</Type>
          <Description>Imputation Options</Description>
          <Name>Tab (208)</Name>
          <ToolId value="208" />
          <Questions>
            <Question>
              <Type>ListBox</Type>
              <Description>Fields to impute</Description>
