    <MetaInfo>
      <NameIsFileName value="False" />
      <Name>Report Footer</Name>
      <Description>Add a footer to a report for output via the Render tool.</Description>
      <CategoryName>Reporting</CategoryName>
      <SearchTags>report, presentation, macro, footer, bottom, number, page, feet, reporting category, foot, Mike Akey</SearchTags>
      <Author>Alteryx, Inc.</Author>
      <Company>Alteryx, Inc.</Company>
      <Copyright>Alteryx, Inc. 2012</Copyright>
      <DescriptionLink actual="" displayed="" />
	  <Example>
        <Description>Open Example</Description>
        <File>07 Reporting\Report_Footer.yxmd</File>
      </Example>
    </MetaInfo>
    <Events>
      <Enabled value="True" />
    </Events>
    <RuntimeProperties>
      <Actions>
        <NoCondition>
          <Type>NoCondition</Type>
          <Description>(Always Run)</Description>
          <True>
            <Action>
              <Type>UpdateValue</Type>
              <Description>InfoText</Description>
              <ToolId value="49" />
              <Mode>Simple</Mode>
              <Variable>InfoText</Variable>
              <Replace value="True" />
              <ReplaceText>Alteryx, Inc. - info@alteryx.com - &lt;Link www.alteryx.com|www.alteryx.com&gt;  - 888 836 4274.</ReplaceText>
              <Destination>3/RichTextString</Destination>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="50" />
              <Expression>IF [PageNumbers] == 'True' THEN [Destination] 
ELSE Replace([Destination], "Page &lt;pg#&gt; of &lt;#pgs&gt;", "")
ENDIF</Expression>
              <Destination>6/RichTextString</Destination>
              <Mode>Expression</Mode>
            </Action>
            <Action>
              <Type>UpdateValueFormula</Type>
              <Description />
              <ToolId value="51" />
              <Expression>IF IsEmpty([CopyrightText]) THEN "{\rtf1\ansi\ansicpg1252\deff0\deflang1033{\fonttbl{\f0\fnil\fcharset0 Microsoft Sans Serif;}}
\viewkind4\uc1\pard\qc\f0\fs29 &lt;hr/&gt; \fs29\par
}" 
ELSE Replace([Destination], "2013 Alteryx, Inc.  All rights reserved. Alteryx is a registered trademark of Alteryx, Inc.", replace([CopyrightText], '[CurrentYear]', left(DateTimeToday(), 4)) )
ENDIF</Expression>
              <Destination>8/RichTextString</Destination>
              <Mode>Expression</Mode>
            </Action>
          </True>
        </NoCondition>
      </Actions>
      <Questions>
        <Question>
          <Type>Tab</Type>
          <Description>Configuration</Description>
          <Name>Tab (57)</Name>
          <ToolId value="57" />
          <Questions>
            <Question>
              <Type>Label</Type>
              <Description>The Report Footer macro will append the created footer to your supplied data, this new field can then be used in a Render tool as a Footer for your report.</Description>
              <Name>Label (52)</Name>
              <ToolId value="52" />
            </Question>
            <Question>
              <Type>TextBox</Type>
              <Description>Copyright text:</Description>
              <Name>CopyrightText</Name>
              <ToolId value="53" />
              <Default>© [CurrentYear] Alteryx, Inc.  All rights reserved. Alteryx is a registered trademark of Alteryx, Inc.</Default>
              <Password value="False" />
              <Multiline value="False" />
              <Hidden value="False" />
            </Question>
            <Question>
              <Type>Label</Type>
              <Description>Using the [CurrentYear] tag in the copyright text box will put the current year into your copyright.</Description>
              <Name>Label (54)</Name>
              <ToolId value="54" />
            </Question>
            <Question>
              <Type>TextBox</Type>
              <Description>Information text: (Will be shown on the bottom line of the footer, left aligned.)</Description>
              <Name>InfoText</Name>
              <ToolId value="55" />
              <Default>Alteryx, Inc. - info@alteryx.com - &lt;Link www.alteryx.com|www.alteryx.com&gt;  - 888 836 4274</Default>
              <Password value="False" />
              <Multiline value="False" />
              <Hidden value="False" />
            </Question>
            <Question>
              <Type>BooleanGroup</Type>
              <Description>Include page numbers. (Will be shown on the bottom line of the footer, right aligned.)</Description>
              <Name>PageNumbers</Name>
              <ToolId value="56" />
              <Questions />
              <Default value="True" />
              <Collapsable value="False" />
            </Question>
            <Question>
              <Type>MacroOutput</Type>
              <Description>Output</Description>
              <Name>Output</Name>
              <ToolId value="60" />
            </Question>
          </Questions>
        </Question>
        <Question>
          <Type>Tab</Type>
          <Description>Report Layout</Description>
          <Name>Tab (58)</Name>
          <ToolId value="58" />
          <Questions>
            <Question>
              <Type>MacroInput</Type>
              <Description>Report Layout</Description>
              <Name>Report Layout</Name>
              <ToolId value="59" />
            </Question>
          </Questions>
        </Question>
      </Questions>
